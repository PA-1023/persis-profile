<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Persis — Profile</title>
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <div class="brand">
        <!-- Replace src with avatar.jpg or a real image URL -->
        <img class="avatar" src="https://via.placeholder.com/150" alt="Persis's photo" />
        <div>
          <h1 class="name">Persis</h1>
          <p class="tagline">Aspiring developer • Learning HTML, CSS & JavaScript</p>
        </div>
      </div>

      <button class="nav-toggle" aria-expanded="false" aria-controls="nav">Menu</button>

      <nav id="nav" class="site-nav">
        <a href="#about">About</a>
        <a href="#skills">Skills</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section id="about" class="card">
      <h2>About</h2>
      <p>Hello — I’m Persis. I’m starting to learn to code and building small projects to practice. I enjoy trying new tools and creating useful things one step at a time.</p>
    </section>

    <section id="skills" class="card">
      <h2>Skills</h2>
      <ul class="skills-list">
        <li>
          <strong>HTML</strong>
          <div class="bar"><span style="width: 90%"></span></div>
        </li>
        <li>
          <strong>CSS</strong>
          <div class="bar"><span style="width: 70%"></span></div>
        </li>
        <li>
          <strong>JavaScript</strong>
          <div class="bar"><span style="width: 40%"></span></div>
        </li>
      </ul>
    </section>

    <section id="projects" class="card">
      <h2>Projects</h2>
      <div class="projects-grid">
        <article class="project">
          <h3>Personal Page</h3>
          <p>This single-page profile built with HTML & CSS.</p>
          <a href="#" class="button">View</a>
        </article>
        <article class="project">
          <h3>Guess the Number</h3>
          <p>Small JavaScript game to practice logic and DOM.</p>
          <a href="#" class="button">View</a>
        </article>
        <article class="project">
          <h3>To‑Do List</h3>
          <p>Practice with arrays and event handling.</p>
          <a href="#" class="button">View</a>
        </article>
      </div>
    </section>

    <section id="contact" class="card">
      <h2>Contact</h2>
      <p>Want to say hi? Email me at <a id="email-link" href="mailto:phaa940@gmail.com">phaa940@gmail.com</a> or find me on GitHub: <a href="https://github.com/PA-1023" target="_blank" rel="noopener">github.com/PA-1023</a>.</p>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>Made with HTML & CSS • <small>Customize this template and make it yours.</small></p>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    const navToggle = document.querySelector('.nav-toggle');
    const nav = document.getElementById('nav');
    navToggle.addEventListener('click', () => {
      const expanded = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('open');
    });

    // Smooth scroll for internal links
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', function (e) {
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
          // close mobile nav
          nav.classList.remove('open');
          navToggle.setAttribute('aria-expanded', 'false');
        }
      });
    });
  </script>
</body>
</html>
